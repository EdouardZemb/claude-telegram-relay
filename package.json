{
  "name": "claude-telegram-relay",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/relay.ts",
    "dev": "bun run --watch src/relay.ts",
    "setup": "bun run setup/install.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:telegram": "bun run setup/test-telegram.ts",
    "test:supabase": "bun run setup/test-supabase.ts",
    "test:voice": "bun run setup/test-voice.ts",
    "setup:launchd": "bun run setup/configure-launchd.ts",
    "setup:services": "bun run setup/configure-services.ts",
    "setup:verify": "bun run setup/verify.ts",
    "dashboard": "bun run dashboard/server.ts",
    "changelog": "git-cliff -o CHANGELOG.md",
    "doc:check": "bun run scripts/doc-check.ts",
    "doc:freshness": "bun run scripts/doc-freshness.ts",
    "smoke": "bun run scripts/smoke-test.ts",
    "cost:estimate": "bun run scripts/cost-estimate.ts",
    "graph:index": "bun run scripts/index-graph.ts",
    "migrate": "bun run scripts/migrate.ts",
    "rotate-token": "./scripts/rotate-token.sh",
    "prepare": "lefthook install",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.2.4",
    "grammy": "^1.21.1",
    "groq-sdk": "^1.1.1",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/bun": "^1.3.9",
    "lefthook": "^2.1.4",
    "postgres": "^3.4.5"
  }
}
